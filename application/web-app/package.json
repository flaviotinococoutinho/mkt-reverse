{
  "name": "web-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "test": "vitest run",
    "lint": "eslint .",
    "preview": "vite preview",
    "smoke:api": "node ./scripts/smoke-flow.mjs",
    "smoke:api:report-json": "SMOKE_REPORT_JSON=1 node ./scripts/smoke-flow.mjs",
    "smoke:api:report-file": "SMOKE_REPORT_PATH=${SMOKE_REPORT_PATH:-./build/smoke-report.json} node ./scripts/smoke-flow.mjs",
    "smoke:api:assert-report": "node ./scripts/assert-smoke-report.mjs",
    "smoke:api:report-check": "SMOKE_REPORT_PATH=${SMOKE_REPORT_PATH:-./build/smoke-report.json} node ./scripts/smoke-flow.mjs && SMOKE_REPORT_INPUT=${SMOKE_REPORT_INPUT:-${SMOKE_REPORT_PATH:-./build/smoke-report.json}} node ./scripts/assert-smoke-report.mjs",
    "smoke:api:auth": "SMOKE_AUTH=1 node ./scripts/smoke-flow.mjs",
    "smoke:api:auth:invalid": "SMOKE_AUTH=1 SMOKE_AUTH_INVALID=1 node ./scripts/smoke-flow.mjs",
    "smoke:ui": "node ./scripts/smoke-ui-routes.mjs",
    "smoke:ui:response-detail-query": "node ./scripts/smoke-response-detail-query.mjs",
    "smoke:mvp": "node ./scripts/smoke-mvp.mjs",
    "smoke:mvp:report-file": "SMOKE_MVP_REPORT_PATH=${SMOKE_MVP_REPORT_PATH:-./build/smoke-mvp-report.json} node ./scripts/smoke-mvp.mjs",
    "smoke:mvp:assert-report": "node ./scripts/assert-smoke-mvp-report.mjs",
    "smoke:mvp:report-check": "SMOKE_MVP_REPORT_PATH=${SMOKE_MVP_REPORT_PATH:-./build/smoke-mvp-report.json} node ./scripts/smoke-mvp.mjs && SMOKE_MVP_REPORT_INPUT=${SMOKE_MVP_REPORT_INPUT:-${SMOKE_MVP_REPORT_PATH:-./build/smoke-mvp-report.json}} node ./scripts/assert-smoke-mvp-report.mjs",
    "smoke:session": "node ./scripts/smoke-session-invalid.mjs"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-query": "^5.90.20",
    "axios": "^1.13.5",
    "clsx": "^2.1.1",
    "lucide-react": "^0.563.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.72.1",
    "react-router-dom": "^7.13.0",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.24",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vitest": "^3.2.4"
  }
}
